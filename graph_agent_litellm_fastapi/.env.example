# API
APP_NAME="Microsoft Graph Agent LiteLLM"
APP_ENV=local
API_KEY_NAME=x-api-key
# Optional. When set, all non-health endpoints require this header value.
LLM_API_KEY=

# LiteLLM
# Any LiteLLM-supported model string, for example:
#   openai/gpt-4o-mini
#   azure/my-deployment
#   anthropic/claude-3-5-sonnet-20241022
#   ollama/llama3.1
#   openai/my-local-model with LITELLM_API_BASE
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY_PROVIDER=
LITELLM_API_BASE=
LITELLM_TEMPERATURE=0
LITELLM_MAX_TOKENS=2048
LITELLM_TIMEOUT_SECONDS=60

# Microsoft Graph application credentials
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default
GRAPH_DEFAULT_API_VERSION=v1.0
GRAPH_TIMEOUT_SECONDS=30

# Agent controls
AGENT_MAX_TURNS=4
AGENT_MAX_TOOL_CALLS=8
AGENT_PARALLEL_READS=true
AGENT_REQUIRE_MUTATION_CONFIRMATION=true

