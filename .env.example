# Security
API_KEY_NAME=x-api-key
LLM_API_KEY=

# LLM provider: azure_openai | nvidia_llama | openai_compatible
LLM_PROVIDER=azure_openai
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=

# Azure OpenAI
OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# Nvidia NIM
NVIDIA_BASE_URL=http://localhost:8000
NVIDIA_MODEL=nvidia/Llama-3.1-Nemotron-Nano-4B-v1.1
NVIDIA_API_KEY=

# OpenAI-compatible endpoint
OPENAI_COMPAT_ENDPOINT=http://34.136.28.121:8000/v1/chat/completions
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=openai-compatible-model
OPENAI_COMPAT_FALLBACK_MODEL=openai-compatible-model

# Microsoft Graph
GRAPH_AGENT_ENABLED=true
GRAPH_EXECUTION_MODE=classic
GRAPH_CODEMODE_MAX_TURNS=3
GRAPH_CODEMODE_CONTEXT_MESSAGES=8
GRAPH_CODEMODE_TOOL_SUMMARY_CHARS=1400
GRAPH_CODEMODE_PARALLEL_READS=true
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default
